<!-- Hero / Search Section -->
<div class="mb-8">
  <div class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 rounded-3xl p-8 sm:p-12 text-white relative overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute -top-10 -right-10 w-48 h-48 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
    <div class="absolute -bottom-10 -left-10 w-60 h-60 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-2xl">
      <p class="text-blue-200 text-sm font-medium mb-2 tracking-wide uppercase">MITAOE Campus Marketplace</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-3 leading-tight">
        Buy, Sell &amp; Donate<br>with Fellow Students
      </h1>
      <p class="text-blue-100 text-sm mb-6">Everything from books to gadgets — all in one trusted place.</p>

      <!-- Search Bar -->
      <div class="flex gap-3">
        <div class="relative flex-1">
          <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
          <input
            type="text"
            id="searchInput"
            placeholder="Search for books, electronics, clothes..."
            class="w-full pl-10 pr-4 py-3.5 bg-white text-gray-800 rounded-2xl text-sm font-medium shadow-lg focus:outline-none focus:ring-4 focus:ring-white/30 transition placeholder-gray-400"
          />
        </div>
        <button onclick="filterProducts()"
                class="ripple-btn bg-white text-blue-600 px-5 py-3.5 rounded-2xl font-semibold text-sm shadow-lg hover:bg-blue-50 transition active:scale-95">
          Search
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="flex flex-wrap items-center gap-3 mb-8">
  <span class="text-sm font-medium text-gray-500">Filter:</span>

  <!-- Price Filter Chips -->
  <button onclick="setFilter('all')" data-filter="all"
          class="filter-chip active-chip px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 active:scale-95">
    All Prices
  </button>
  <button onclick="setFilter('low')" data-filter="low"
          class="filter-chip px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 active:scale-95">
    Below ₹1,000
  </button>
  <button onclick="setFilter('mid')" data-filter="mid"
          class="filter-chip px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 active:scale-95">
    ₹1,000 – ₹5,000
  </button>
  <button onclick="setFilter('high')" data-filter="high"
          class="filter-chip px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 active:scale-95">
    Above ₹5,000
  </button>
  <button onclick="setFilter('free')" data-filter="free"
          class="filter-chip px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 active:scale-95">
    🎁 Free Donations
  </button>

  <!-- Results count -->
  <span id="resultCount" class="ml-auto text-sm text-gray-400"></span>
</div>

<!-- Section title -->
<div class="flex justify-between items-center mb-5">
  <h2 class="text-xl font-bold text-gray-800">Popular on Campus</h2>
</div>

<!-- Product Grid -->
<div id="productGrid" class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-5">

  <% ads.forEach((ad, i) => { %>
    <a href="/ads/<%= ad._id %>"
       class="product-card group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden flex flex-col"
       style="animation: slideUp 0.4s ease-out <%= i * 0.04 %>s both;"
       data-title="<%= (ad.title || '').toLowerCase() %>"
       data-price="<%= ad.price || 0 %>"
       data-donation="<%= ad.isDonation %>">

      <!-- Image -->
      <div class="relative overflow-hidden" style="height: 180px;">
        <img
          src="<%= ad.image || '/default.jpg' %>"
          alt="<%= ad.title %>"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          onerror="this.src='/default.jpg'"
        />
        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

        <!-- Badge -->
        <% if (ad.isDonation === true) { %>
          <span class="absolute top-2.5 left-2.5 bg-emerald-500 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow-md">
            🎁 Free
          </span>
        <% } %>
      </div>

      <!-- Details -->
      <div class="p-3.5 flex flex-col gap-1 flex-1">
        <h3 class="text-sm font-semibold text-gray-800 truncate group-hover:text-blue-600 transition-colors">
          <%= ad.title %>
        </h3>
        <p class="text-base font-bold <%= ad.isDonation ? 'text-emerald-600' : 'text-blue-600' %>">
          <%= ad.isDonation ? "FREE" : "₹" + (ad.price || 0).toLocaleString() %>
        </p>
      </div>
    </a>
  <% }) %>

</div>

<!-- Empty state -->
<div id="emptyState" class="hidden flex flex-col items-center justify-center py-20 text-center">
  <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
    <i class="fas fa-search text-gray-300 text-2xl"></i>
  </div>
  <p class="text-gray-500 font-medium">No products found</p>
  <p class="text-gray-400 text-sm mt-1">Try adjusting your search or filters</p>
</div>

<style>
  /* Filter chip styles */
  .filter-chip {
    background: white;
    border-color: #e5e7eb;
    color: #6b7280;
  }
  .filter-chip:hover {
    border-color: #3b82f6;
    color: #2563eb;
    background: #eff6ff;
  }
  .active-chip {
    background: #2563eb !important;
    border-color: #2563eb !important;
    color: white !important;
    box-shadow: 0 4px 12px rgba(37,99,235,0.25);
  }
</style>

<script>
  const searchInput = document.getElementById('searchInput');
  const products    = document.querySelectorAll('.product-card');
  const emptyState  = document.getElementById('emptyState');
  const resultCount = document.getElementById('resultCount');
  let currentFilter = 'all';

  function setFilter(val) {
    currentFilter = val;
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active-chip'));
    document.querySelector(`[data-filter="${val}"]`)?.classList.add('active-chip');
    filterProducts();
  }

  function filterProducts() {
    const q = searchInput.value.trim().toLowerCase();
    let visible = 0;

    products.forEach(card => {
      const title      = card.dataset.title || '';
      const price      = parseInt(card.dataset.price) || 0;
      const isDonation = card.dataset.donation === 'true';

      const matchSearch = !q || title.includes(q);
      let matchFilter = true;

      if (currentFilter === 'free') {
        matchFilter = isDonation;
      } else if (!isDonation) {
        if      (currentFilter === 'low')  matchFilter = price < 1000;
        else if (currentFilter === 'mid')  matchFilter = price >= 1000 && price <= 5000;
        else if (currentFilter === 'high') matchFilter = price > 5000;
      }

      const show = matchSearch && matchFilter;
      card.style.display    = show ? '' : 'none';
      card.style.opacity    = show ? '1' : '0';
      if (show) visible++;
    });

    emptyState.classList.toggle('hidden', visible > 0);
    resultCount.textContent = visible > 0 ? `${visible} item${visible !== 1 ? 's' : ''}` : '';
  }

  // Debounced live search
  let debounceTimer;
  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(filterProducts, 200);
  });

  searchInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') { clearTimeout(debounceTimer); filterProducts(); }
  });

  // Count on load
  filterProducts();
  document.querySelectorAll('.filter-chip').forEach(c => {
    c.addEventListener('mousedown', e => e.preventDefault());
  });
</script>
