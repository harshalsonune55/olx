<div class="max-w-lg mx-auto flex flex-col animate-fade-in" style="height: calc(100vh - 160px); min-height: 500px;">

  <!-- Chat Header -->
  <div class="flex items-center gap-3 bg-white border border-gray-100 rounded-t-3xl px-5 py-4 shadow-sm flex-shrink-0">
    <a href="/inbox"
       class="w-8 h-8 flex items-center justify-center rounded-xl hover:bg-gray-100 text-gray-500 transition-all mr-1">
      <i class="fas fa-arrow-left text-sm"></i>
    </a>
    <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold shadow-sm">
      <%= otherUser.username[0].toUpperCase() %>
    </div>
    <div>
      <div class="font-semibold text-gray-900 text-sm"><%= otherUser.username %></div>
      <div class="text-xs text-green-500 font-medium">Online</div>
    </div>
  </div>

  <!-- Messages -->
  <div class="chat-box flex-1 bg-gray-50 border-x border-gray-100 p-4 overflow-y-auto flex flex-col gap-2.5" id="chatBox">
    <% messages.forEach(msg => { %>
      <% const isMe = msg.sender.equals(currentUser._id); %>
      <% const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); %>

      <div class="flex <%= isMe ? 'justify-end' : 'justify-start' %> items-end gap-2">
        <% if (!isMe) { %>
          <div class="w-6 h-6 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0 mb-0.5">
            <%= otherUser.username[0].toUpperCase() %>
          </div>
        <% } %>
        <div class="max-w-[75%]">
          <div class="<%= isMe
            ? 'bg-gradient-to-br from-blue-600 to-indigo-600 text-white rounded-2xl rounded-br-sm'
            : 'bg-white text-gray-800 rounded-2xl rounded-bl-sm shadow-sm border border-gray-100'
          %> px-4 py-2.5">
            <p class="text-sm leading-relaxed"><%= msg.text %></p>
          </div>
          <p class="text-[10px] text-gray-400 mt-1 <%= isMe ? 'text-right' : 'text-left' %>"><%= time %></p>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Input Bar -->
  <div class="flex items-center gap-3 bg-white border border-gray-100 rounded-b-3xl px-4 py-3.5 shadow-sm flex-shrink-0">
    <input
      id="messageInput"
      class="flex-1 bg-gray-100 rounded-2xl px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-blue-500 transition placeholder-gray-400"
      placeholder="Type a message..."
      autocomplete="off"
    />
    <button
      id="sendBtn"
      type="button"
      class="ripple-btn w-10 h-10 bg-gradient-to-br from-blue-600 to-indigo-600 hover:shadow-lg hover:shadow-blue-200 text-white rounded-2xl flex items-center justify-center transition-all duration-200 hover:scale-105 active:scale-95 flex-shrink-0">
      <i class="fas fa-paper-plane text-xs"></i>
    </button>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket  = io();
  socket.emit("join", "<%= currentUser._id %>");

  const input   = document.getElementById("messageInput");
  const sendBtn = document.getElementById("sendBtn");
  const chatBox = document.getElementById("chatBox");

  chatBox.scrollTop = chatBox.scrollHeight;

  if (Notification.permission !== "granted") Notification.requestPermission();

  sendBtn.addEventListener("click", sendMessage);
  input.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });

  function sendMessage() {
    const message = input.value.trim();
    if (!message) return;

    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

    socket.emit("sendMessage", {
      text: message,
      receiverId: "<%= otherUser._id %>",
      senderId:   "<%= currentUser._id %>"
    });

    appendMessage(message, time, true);
    input.value = "";
    input.focus();
  }

  socket.emit("markRead", {
    senderId:   "<%= otherUser._id %>",
    receiverId: "<%= currentUser._id %>"
  });

  socket.on("receiveMessage", (data) => {
    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    appendMessage(data.text, time, false);

    socket.emit("markRead", {
      senderId:   "<%= otherUser._id %>",
      receiverId: "<%= currentUser._id %>"
    });

    if (Notification.permission === "granted") {
      new Notification("<%= otherUser.username %>", { body: data.text });
    }
  });

  function appendMessage(text, time, isMe) {
    const wrapper = document.createElement("div");
    wrapper.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-2`;
    wrapper.style.animation = 'scaleIn 0.2s ease-out';

    const avatarHtml = isMe ? '' : `
      <div class="w-6 h-6 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0 mb-0.5">
        ${"<%= otherUser.username[0].toUpperCase() %>"}
      </div>`;

    wrapper.innerHTML = `
      ${avatarHtml}
      <div class="max-w-[75%]">
        <div class="${isMe
          ? 'bg-gradient-to-br from-blue-600 to-indigo-600 text-white rounded-2xl rounded-br-sm'
          : 'bg-white text-gray-800 rounded-2xl rounded-bl-sm shadow-sm border border-gray-100'
        } px-4 py-2.5">
          <p class="text-sm leading-relaxed">${escHtml(text)}</p>
        </div>
        <p class="text-[10px] text-gray-400 mt-1 ${isMe ? 'text-right' : 'text-left'}">${time}</p>
      </div>`;

    chatBox.appendChild(wrapper);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
