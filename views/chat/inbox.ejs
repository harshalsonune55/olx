<div class="max-w-lg mx-auto animate-slide-up">

  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 bg-purple-100 rounded-2xl flex items-center justify-center">
      <i class="fas fa-envelope text-purple-600"></i>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Messages</h2>
      <p class="text-sm text-gray-500"><%= conversations.length %> conversation<%= conversations.length !== 1 ? 's' : '' %></p>
    </div>
  </div>

  <% if (conversations.length === 0) { %>
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div class="w-20 h-20 bg-gray-100 rounded-3xl flex items-center justify-center mb-5">
        <i class="fas fa-comments text-gray-300 text-3xl"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-700 mb-2">No messages yet</h3>
      <p class="text-gray-400 text-sm mb-6">Start a conversation by visiting a listing and clicking Chat.</p>
      <a href="/"
         class="ripple-btn bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-3 rounded-2xl text-sm font-semibold hover:shadow-lg hover:shadow-blue-200 transition-all active:scale-95">
        Browse Listings
      </a>
    </div>
  <% } else { %>
    <div class="flex flex-col gap-2">
      <% conversations.forEach((conv, i) => { %>
        <a href="/chat/<%= conv.otherUser._id %>"
           class="flex items-center gap-4 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-blue-200 transition-all duration-200 group"
           style="animation: slideUp 0.3s ease-out <%= i * 0.05 %>s both;">

          <!-- Avatar -->
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-lg flex-shrink-0 shadow-sm group-hover:scale-105 transition-transform">
            <%= conv.otherUser.username[0].toUpperCase() %>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0">
            <div class="flex justify-between items-baseline">
              <span class="font-semibold text-gray-800 group-hover:text-blue-600 transition-colors">
                <%= conv.otherUser.username %>
              </span>
              <span class="text-xs text-gray-400 flex-shrink-0 ml-2">
                <%= new Date(conv.time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
              </span>
            </div>
            <p class="text-sm text-gray-400 truncate mt-0.5"><%= conv.lastMessage %></p>
          </div>

          <i class="fas fa-chevron-right text-xs text-gray-300 group-hover:text-blue-400 transition-colors flex-shrink-0"></i>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
