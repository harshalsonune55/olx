<div class="max-w-lg mx-auto animate-slide-up">

  <div class="mb-6">
    <a href="/profile" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-blue-600 transition-colors mb-3 group">
      <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
      Back to Profile
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Edit Profile</h1>
    <p class="text-gray-500 text-sm mt-1">Keep your campus details up to date.</p>
  </div>

  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sm:p-8">
    <form action="/profile/edit" method="POST" class="space-y-5">

      <div class="space-y-1.5">
        <label for="college" class="block text-sm font-semibold text-gray-700">College</label>
        <div class="relative">
          <i class="fas fa-school absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
          <input type="text" id="college" name="college"
                 class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                 value="<%= user.college || '' %>"
                 placeholder="e.g. MITAOE" />
        </div>
      </div>

      <div class="space-y-1.5">
        <label for="major" class="block text-sm font-semibold text-gray-700">Major / Department</label>
        <div class="relative">
          <i class="fas fa-book absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
          <input type="text" id="major" name="major"
                 class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                 value="<%= user.major || '' %>"
                 placeholder="e.g. Computer Science" />
        </div>
      </div>

      <div class="space-y-1.5">
        <label for="year" class="block text-sm font-semibold text-gray-700">Year</label>
        <div class="relative">
          <i class="fas fa-calendar absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
          <select id="year" name="year"
                  class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white appearance-none cursor-pointer">
            <option value="">Select your year</option>
            <option value="freshman"  <%= user.year === 'freshman'  ? 'selected' : '' %>>1st Year (Freshman)</option>
            <option value="sophomore" <%= user.year === 'sophomore' ? 'selected' : '' %>>2nd Year (Sophomore)</option>
            <option value="junior"    <%= user.year === 'junior'    ? 'selected' : '' %>>3rd Year (Junior)</option>
            <option value="senior"    <%= user.year === 'senior'    ? 'selected' : '' %>>4th Year (Senior)</option>
            <option value="graduate"  <%= user.year === 'graduate'  ? 'selected' : '' %>>Graduate</option>
          </select>
          <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-300 text-xs pointer-events-none"></i>
        </div>
      </div>

      <div class="space-y-1.5">
        <label for="studentId" class="block text-sm font-semibold text-gray-700">Student ID</label>
        <div class="relative">
          <i class="fas fa-id-card absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
          <input type="text" id="studentId" name="studentId"
                 class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                 value="<%= user.studentId || '' %>"
                 placeholder="e.g. MIT2021001" />
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <a href="/profile"
           class="ripple-btn flex-1 flex items-center justify-center border border-gray-200 text-gray-600 py-3 rounded-2xl text-sm font-medium hover:bg-gray-50 transition-all active:scale-95">
          Cancel
        </a>
        <button type="submit"
                class="ripple-btn flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3 rounded-2xl font-semibold text-sm hover:shadow-lg hover:shadow-blue-200 transition-all duration-200 hover:-translate-y-0.5 active:scale-95">
          Save Changes
        </button>
      </div>

    </form>
  </div>
</div>
