<div class="max-w-2xl mx-auto animate-slide-up">

  <!-- Header -->
  <div class="mb-8">
    <a href="/ads/<%= ad._id %>" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-blue-600 transition-colors mb-4 group">
      <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
      Back to Listing
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Edit Listing</h1>
    <p class="text-gray-500 text-sm mt-1">Update the details of your listing.</p>
  </div>

  <form action="/ads/<%= ad._id %>/edit" method="POST"
        class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sm:p-8 space-y-6">

    <!-- Title -->
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-gray-700">Title</label>
      <input type="text" name="title" required value="<%= ad.title %>"
             class="w-full px-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
    </div>

    <!-- Description -->
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-gray-700">Description</label>
      <textarea name="description" rows="3" required
                class="w-full px-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"><%= ad.description %></textarea>
    </div>

    <!-- Price -->
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-gray-700">Price</label>
      <div class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold text-sm">₹</span>
        <input type="number" name="price" required value="<%= ad.price %>" min="0"
               class="w-full pl-8 pr-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
      </div>
    </div>

    <!-- Image URL -->
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-gray-700">Image URL</label>
      <input type="url" name="image" required id="editImageUrl" value="<%= ad.image %>"
             class="w-full px-4 py-3 border border-gray-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
      <!-- Preview -->
      <div class="mt-3 rounded-2xl overflow-hidden border border-gray-100 h-44 bg-gray-50">
        <img id="editPreviewImg" src="<%= ad.image %>" alt="Preview"
             class="w-full h-full object-cover"
             onerror="this.src='/default.jpg'" />
      </div>
    </div>

    <!-- Actions -->
    <div class="flex gap-3 pt-2">
      <a href="/ads/<%= ad._id %>"
         class="ripple-btn flex-1 flex items-center justify-center border border-gray-200 text-gray-600 py-3 rounded-2xl text-sm font-medium hover:bg-gray-50 transition-all active:scale-95">
        Cancel
      </a>
      <button type="submit"
              class="ripple-btn flex-1 bg-gradient-to-r from-amber-500 to-orange-500 text-white py-3 rounded-2xl font-semibold text-sm hover:shadow-lg hover:shadow-amber-200 transition-all duration-200 hover:-translate-y-0.5 active:scale-95">
        <i class="fas fa-save mr-2"></i>Save Changes
      </button>
    </div>

  </form>
</div>

<script>
  let previewTimer;
  document.getElementById('editImageUrl').addEventListener('input', function() {
    clearTimeout(previewTimer);
    previewTimer = setTimeout(() => {
      const img = document.getElementById('editPreviewImg');
      img.src = this.value || '/default.jpg';
    }, 600);
  });
</script>
