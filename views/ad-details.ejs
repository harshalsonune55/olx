<div class="animate-slide-up">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
    <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
    <i class="fas fa-chevron-right text-xs"></i>
    <span class="text-gray-600 font-medium truncate max-w-xs"><%= ad.title %></span>
  </nav>

  <div class="grid md:grid-cols-2 gap-8 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">

    <!-- Left: Image -->
    <div class="relative bg-gray-50 flex items-center justify-center" style="min-height: 380px;">
      <img
        src="<%= ad.image || '/default.jpg' %>"
        alt="<%= ad.title %>"
        class="w-full h-full object-cover"
        style="max-height: 420px;"
        onerror="this.src='/default.jpg'"
      />
      <% if (ad.isDonation === true) { %>
        <span class="absolute top-4 left-4 bg-emerald-500 text-white text-sm font-semibold px-3 py-1.5 rounded-full shadow-md">
          🎁 Free Donation
        </span>
      <% } %>
    </div>

    <!-- Right: Info + Actions -->
    <div class="p-6 sm:p-8 flex flex-col">

      <!-- Title & Price -->
      <div class="mb-5">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 leading-tight"><%= ad.title %></h1>
        <div class="flex items-center gap-3">
          <% if (ad.isDonation) { %>
            <span class="text-2xl font-extrabold text-emerald-600">FREE</span>
            <span class="bg-emerald-50 text-emerald-700 text-xs font-semibold px-3 py-1 rounded-full border border-emerald-200">Donation</span>
          <% } else { %>
            <span class="text-2xl font-extrabold text-blue-600">₹<%= (ad.price || 0).toLocaleString() %></span>
          <% } %>
        </div>
      </div>

      <!-- Description -->
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Description</h3>
        <p class="text-gray-700 leading-relaxed text-sm"><%= ad.description %></p>
      </div>

      <!-- Seller info (if available) -->
      <% if (ad.user) { %>
        <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl mb-6 border border-gray-100">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm shadow-sm flex-shrink-0">
            <%= (ad.user.username || 'U')[0].toUpperCase() %>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-0.5">Listed by</p>
            <p class="text-sm font-semibold text-gray-800"><%= ad.user.username || 'Unknown' %></p>
          </div>
        </div>
      <% } %>

      <!-- Actions -->
      <div class="flex flex-col gap-3 mt-auto">

        <% if (currentUser && ad.user && ad.user._id && currentUser._id.toString() !== ad.user._id.toString()) { %>

          <!-- Buy Now -->
          <form action="/orders/<%= ad._id %>" method="POST">
            <button type="submit"
                    class="ripple-btn w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3.5 rounded-2xl font-semibold text-sm hover:shadow-lg hover:shadow-blue-200 transition-all duration-200 hover:-translate-y-0.5 active:scale-95">
              <i class="fas fa-bolt mr-2"></i>Buy Now
            </button>
          </form>

          <div class="grid grid-cols-2 gap-3">
            <!-- Add to Cart -->
            <form action="/cart/<%= ad._id %>" method="POST">
              <button type="submit"
                      class="ripple-btn w-full bg-blue-50 text-blue-600 border border-blue-200 py-3 rounded-2xl font-semibold text-sm hover:bg-blue-100 transition-all duration-200 active:scale-95">
                <i class="fas fa-shopping-bag mr-1.5"></i>Add to Cart
              </button>
            </form>

            <!-- Chat -->
            <a href="/chat/<%= ad.user._id %>"
               class="ripple-btn flex items-center justify-center bg-purple-50 text-purple-600 border border-purple-200 py-3 rounded-2xl font-semibold text-sm hover:bg-purple-100 transition-all duration-200 active:scale-95">
              <i class="fas fa-comment-dots mr-1.5"></i>Chat
            </a>
          </div>

        <% } else if (!currentUser) { %>
          <a href="/login"
             class="ripple-btn w-full flex items-center justify-center bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3.5 rounded-2xl font-semibold text-sm hover:shadow-lg hover:shadow-blue-200 transition-all duration-200 active:scale-95">
            Login to Buy / Chat
          </a>

        <% } else if (currentUser && ad.user && ad.user._id && currentUser._id.toString() === ad.user._id.toString()) { %>
          <!-- Owner controls -->
          <div class="flex gap-3">
            <a href="/ads/<%= ad._id %>/edit"
               class="ripple-btn flex-1 flex items-center justify-center bg-amber-50 text-amber-600 border border-amber-200 py-3 rounded-2xl font-semibold text-sm hover:bg-amber-100 transition-all duration-200 active:scale-95">
              <i class="fas fa-pen mr-2"></i>Edit
            </a>
            <form action="/ads/<%= ad._id %>/delete" method="POST" class="flex-1"
                  onsubmit="return confirm('Delete this listing?')">
              <button type="submit"
                      class="ripple-btn w-full flex items-center justify-center bg-red-50 text-red-600 border border-red-200 py-3 rounded-2xl font-semibold text-sm hover:bg-red-100 transition-all duration-200 active:scale-95">
                <i class="fas fa-trash mr-2"></i>Delete
              </button>
            </form>
          </div>
        <% } %>

      </div>

    </div>
  </div>

  <!-- Back link -->
  <a href="/" class="inline-flex items-center gap-2 mt-6 text-sm text-gray-500 hover:text-blue-600 transition-colors font-medium group">
    <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
    Back to Listings
  </a>

</div>
