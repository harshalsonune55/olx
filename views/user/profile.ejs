<div class="max-w-lg mx-auto animate-slide-up">

  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">

    <!-- Profile Header -->
    <div class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 px-6 pt-8 pb-10 relative">
      <div class="absolute -bottom-6 left-6">
        <div class="w-16 h-16 rounded-2xl bg-white shadow-lg flex items-center justify-center text-2xl font-bold text-blue-600 border-4 border-white">
          <%= user.username[0].toUpperCase() %>
        </div>
      </div>
      <div class="ml-24">
        <h1 class="text-lg font-bold text-white"><%= user.username %></h1>
        <p class="text-blue-200 text-sm">@<%= user.username %></p>
      </div>
    </div>

    <!-- Body -->
    <div class="pt-10 px-6 pb-6">
      <!-- Profile complete badge -->
      <% const isComplete = user.college && user.major && user.year && user.studentId; %>
      <div class="flex items-center justify-between mb-5">
        <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full
              <%= isComplete ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-amber-50 text-amber-700 border border-amber-200' %>">
          <i class="fas <%= isComplete ? 'fa-circle-check' : 'fa-circle-exclamation' %> text-xs"></i>
          <%= isComplete ? 'Profile complete' : 'Profile incomplete' %>
        </span>
        <a href="/profile/edit"
           class="ripple-btn text-xs text-blue-600 border border-blue-200 bg-blue-50 px-3 py-1.5 rounded-xl hover:bg-blue-100 transition-all duration-200 font-medium active:scale-95">
          <i class="fas fa-pen mr-1.5"></i>Edit
        </a>
      </div>

      <!-- Fields -->
      <div class="space-y-1 text-sm">

        <% const fields = [
          { icon: 'fa-envelope', label: 'Email',      value: user.email },
          { icon: 'fa-school',   label: 'College',    value: user.college },
          { icon: 'fa-book',     label: 'Major',      value: user.major },
          { icon: 'fa-calendar', label: 'Year',       value: user.year },
          { icon: 'fa-id-card',  label: 'Student ID', value: user.studentId },
        ]; %>

        <% fields.forEach(f => { %>
          <div class="flex items-center gap-3 py-3 border-b border-gray-50 last:border-0">
            <div class="w-8 h-8 rounded-xl bg-gray-50 flex items-center justify-center flex-shrink-0">
              <i class="fas <%= f.icon %> text-gray-400 text-xs"></i>
            </div>
            <span class="text-gray-400 w-24 flex-shrink-0 text-xs font-medium"><%= f.label %></span>
            <% if (f.value) { %>
              <span class="text-gray-800 font-medium text-sm"><%= f.value %></span>
            <% } else { %>
              <button onclick="document.getElementById('editModal').classList.remove('hidden')"
                      class="text-xs text-blue-500 hover:text-blue-700 font-medium transition">
                + Add
              </button>
            <% } %>
          </div>
        <% }) %>
      </div>

      <!-- Actions -->
      <div class="mt-6 flex gap-3">
        <% if (!isComplete) { %>
          <button onclick="document.getElementById('editModal').classList.remove('hidden')"
                  class="ripple-btn flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-sm py-2.5 rounded-2xl font-semibold hover:shadow-lg hover:shadow-blue-200 transition-all active:scale-95">
            Complete Profile
          </button>
        <% } %>
        <a href="/"
           class="ripple-btn <%= isComplete ? 'flex-1' : '' %> flex items-center justify-center text-sm text-gray-500 border border-gray-200 py-2.5 px-4 rounded-2xl hover:bg-gray-50 transition-all active:scale-95">
          Back to Home
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Quick Edit Modal -->
<div id="editModal" class="hidden fixed inset-0 bg-black/50 flex items-end sm:items-center justify-center z-50 px-4 pb-4 sm:pb-0">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm p-6 animate-slide-up">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-base font-bold text-gray-900">Complete your profile</h3>
      <button onclick="document.getElementById('editModal').classList.add('hidden')"
              class="w-8 h-8 flex items-center justify-center rounded-xl hover:bg-gray-100 text-gray-400 transition">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <form action="/profile/edit" method="POST" class="space-y-3">
      <% const editFields = [
        { name: 'college',   label: 'College',    placeholder: 'e.g. MITAOE',          value: user.college },
        { name: 'major',     label: 'Major',      placeholder: 'e.g. Computer Science', value: user.major },
        { name: 'year',      label: 'Year',       placeholder: 'e.g. 2nd Year',         value: user.year },
        { name: 'studentId', label: 'Student ID', placeholder: 'e.g. MIT2021001',       value: user.studentId },
      ]; %>
      <% editFields.forEach(f => { %>
        <div>
          <label class="text-xs font-semibold text-gray-500 block mb-1"><%= f.label %></label>
          <input name="<%= f.name %>" value="<%= f.value || '' %>" placeholder="<%= f.placeholder %>"
                 class="w-full border border-gray-200 rounded-2xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
        </div>
      <% }) %>
      <div class="flex gap-2 pt-1">
        <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')"
                class="flex-1 border border-gray-200 text-gray-600 text-sm py-2.5 rounded-2xl hover:bg-gray-50 transition font-medium">
          Cancel
        </button>
        <button type="submit"
                class="ripple-btn flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-sm py-2.5 rounded-2xl hover:shadow-lg hover:shadow-blue-200 transition-all font-semibold active:scale-95">
          Save
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Close modal on backdrop click
  document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.add('hidden');
  });
</script>
