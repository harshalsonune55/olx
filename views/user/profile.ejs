<div class="min-h-screen bg-gray-100 px-4 py-8 flex items-center justify-center">
  <div class="w-full max-w-xl bg-white rounded-xl shadow border border-gray-100 p-6 relative">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
      <div class="w-14 h-14 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-xl font-semibold">
        <%= user.username[0].toUpperCase() %>
      </div>
      <div class="flex-1">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-lg font-semibold text-gray-800"><%= user.username %></span>
          <% const isComplete = user.college && user.major && user.year && user.studentId; %>
          <span class="text-xs px-2 py-0.5 rounded-full <%= isComplete ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
            <%= isComplete ? 'Profile complete' : 'Profile incomplete' %>
          </span>
        </div>
        <span class="text-sm text-gray-500">@<%= user.username %></span>
      </div>
      <a href="/profile/edit" class="text-sm text-blue-600 border border-blue-200 px-3 py-1.5 rounded-lg hover:bg-blue-50 transition">Edit profile</a>
    </div>

    <!-- Fields -->
    <div class="divide-y divide-gray-100 text-sm">
      <div class="flex items-center py-3 gap-3">
        <span class="text-gray-400 w-28 flex-shrink-0">Email</span>
        <span class="text-gray-800"><%= user.email || '—' %></span>
      </div>
      <div class="flex items-center py-3 gap-3">
        <span class="text-gray-400 w-28 flex-shrink-0">College</span>
        <% if (user.college) { %>
          <span class="text-gray-800"><%= user.college %></span>
        <% } else { %>
          <button onclick="document.getElementById('editModal').classList.remove('hidden')"
            class="text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-3 py-1 rounded-full hover:bg-yellow-100 transition">
            + Add
          </button>
        <% } %>
      </div>
      <div class="flex items-center py-3 gap-3">
        <span class="text-gray-400 w-28 flex-shrink-0">Major</span>
        <% if (user.major) { %>
          <span class="text-gray-800"><%= user.major %></span>
        <% } else { %>
          <button onclick="document.getElementById('editModal').classList.remove('hidden')"
            class="text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-3 py-1 rounded-full hover:bg-yellow-100 transition">
            + Add
          </button>
        <% } %>
      </div>
      <div class="flex items-center py-3 gap-3">
        <span class="text-gray-400 w-28 flex-shrink-0">Year</span>
        <% if (user.year) { %>
          <span class="text-gray-800"><%= user.year %></span>
        <% } else { %>
          <button onclick="document.getElementById('editModal').classList.remove('hidden')"
            class="text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-3 py-1 rounded-full hover:bg-yellow-100 transition">
            + Add
          </button>
        <% } %>
      </div>
      <div class="flex items-center py-3 gap-3">
        <span class="text-gray-400 w-28 flex-shrink-0">Student ID</span>
        <% if (user.studentId) { %>
          <span class="text-gray-800"><%= user.studentId %></span>
        <% } else { %>
          <button onclick="document.getElementById('editModal').classList.remove('hidden')"
            class="text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-3 py-1 rounded-full hover:bg-yellow-100 transition">
            + Add
          </button>
        <% } %>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-6 pt-4 border-t border-gray-100 flex gap-3">
      <% if (!isComplete) { %>
        <button onclick="document.getElementById('editModal').classList.remove('hidden')"
          class="bg-blue-600 text-white text-sm px-4 py-2 rounded-lg hover:bg-blue-700 transition font-medium">
          Complete your profile
        </button>
      <% } %>
      <a href="/" class="text-sm text-gray-500 border border-gray-200 px-4 py-2 rounded-lg hover:bg-gray-50 transition">Back</a>
    </div>
  </div>
</div>

<!-- Modal -->
<div id="editModal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50 px-4">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
    <h3 class="text-base font-semibold text-gray-800 mb-1">Complete your profile</h3>
    <p class="text-sm text-gray-500 mb-4">Fill in the missing details below.</p>

    <form action="/profile/edit" method="POST" class="space-y-3">
      <div>
        <label class="text-xs text-gray-500 block mb-1">College</label>
        <input name="college" value="<%= user.college || '' %>" placeholder="e.g. Engineering"
          class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-400" />
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Major</label>
        <input name="major" value="<%= user.major || '' %>" placeholder="e.g. Computer Science"
          class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-400" />
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Year</label>
        <input name="year" value="<%= user.year || '' %>" placeholder="e.g. 2nd year"
          class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-400" />
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Student ID</label>
        <input name="studentId" value="<%= user.studentId || '' %>" placeholder="e.g. S12345678"
          class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-400" />
      </div>
      <div class="flex gap-2 pt-2">
        <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')"
          class="flex-1 border border-gray-200 text-gray-600 text-sm py-2 rounded-lg hover:bg-gray-50 transition">
          Cancel
        </button>
        <button type="submit"
          class="flex-1 bg-blue-600 text-white text-sm py-2 rounded-lg hover:bg-blue-700 transition font-medium">
          Save
        </button>
      </div>
    </form>
  </div>
</div>